{
  "name": "@dependably/svelte-docs",
  "version": "0.2.4",
  "description": "A small, reusable Svelte 5 documentation engine: client-rendered sidebar/search/version/i18n docs from a markdown git repo, plus a build toolkit that turns markdown into a static content bundle.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "files": [
    "src",
    "build"
  ],
  "svelte": "./src/index.js",
  "exports": {
    ".": {
      "svelte": "./src/index.js",
      "default": "./src/index.js"
    },
    "./build": "./build/index.js",
    "./styles.css": "./src/styles/docs.css"
  },
  "bin": {
    "svelte-docs-build": "./build/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:lib": "vite build",
    "demo:content": "node build/cli.js --local demo/sample-content --out demo/public/docs-content",
    "predemo": "npm run demo:content",
    "demo": "vite",
    "check": "node --check build/cli.js && node --check build/index.js",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom.json",
    "sbom:prod": "cyclonedx-npm --omit dev --output-format json --output-file sbom-prod.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "dependencies": {
    "@shikijs/rehype": "3.23.0",
    "flexsearch": "0.7.43",
    "hast-util-to-string": "3.0.1",
    "js-yaml": "4.2.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-sanitize": "6.0.0",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "9.39.4",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "eslint": "9.39.4",
    "eslint-plugin-svelte": "3.19.0",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.2",
    "svelte": "5.55.7",
    "svelte-eslint-parser": "1.7.1",
    "vite": "8.1.0"
  },
  "allowScripts": {
    "fsevents": true
  }
}
